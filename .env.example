APP_ENV=development
APP_NAME=강냉이 에스크
POSTGRES_PASSWORD=replace-with-a-strong-database-password
DATABASE_URL=postgresql+psycopg://knuask:replace-with-a-strong-database-password@postgres:5432/knuask
CORS_ORIGINS=["http://localhost","http://localhost:5173","http://localhost:8080"]
OPENAI_API_KEY=
OPENAI_CHAT_MODEL=gpt-4.1-mini
GEMINI_API_KEY=
GEMINI_CHAT_MODEL=gemini-3.1-flash-lite
GEMINI_API_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_CHAT_TIMEOUT=10
GEMINI_CHAT_MAX_OUTPUT_TOKENS=1536
GEMINI_THINKING_LEVEL=low
GEMINI_MAX_RETRIES=2
OPENAI_ENRICHMENT_MODEL=gpt-5.6-sol
OPENAI_ENRICHMENT_REASONING_EFFORT=medium
OPENAI_IMAGE_DETAIL=original
CHAT_PROVIDER=gemini
OLLAMA_CHAT_MODEL=qwen3.5:4b
OLLAMA_CHAT_KEEP_ALIVE=20m
OLLAMA_CHAT_TIMEOUT=240
OLLAMA_CHAT_NUM_CTX=8192
OLLAMA_STRUCTURING_NUM_CTX=16384
OLLAMA_CHAT_NUM_PREDICT=768
OLLAMA_STRUCTURING_NUM_PREDICT=2048
LOCAL_AI_COMPLEX_QUERIES_ONLY=true
LLM_CANDIDATE_RERANKING_ENABLED=false
NOTICE_STRUCTURING_PROVIDER=codex
CODEX_ENRICHMENT_ENABLED=false
# 질문이 들어왔을 때만 QueryPlan→기존 DB→공식 홈페이지→근거 검증을 실행합니다.
ON_DEMAND_SEARCH_ENABLED=true
ON_DEMAND_LIVE_SEARCH_ENABLED=true
ON_DEMAND_CODEX_ENABLED=true
ON_DEMAND_CODEX_PROVIDER=codex_exec
ON_DEMAND_CODEX_MODEL=gpt-5.6-sol
ON_DEMAND_TIMEOUT_SECONDS=30
ON_DEMAND_PAGE_TIMEOUT_SECONDS=5
ON_DEMAND_MAX_SEARCHES=2
ON_DEMAND_MAX_URLS=6
ON_DEMAND_TOP_SCORE_THRESHOLD=0.58
ON_DEMAND_ALLOWED_DOMAINS=kangnam.ac.kr,web.kangnam.ac.kr
ON_DEMAND_PROMPT_VERSION=ondemand-v22
MISSING_EVIDENCE_RECOVERY_ENABLED=true
MISSING_EVIDENCE_RECOVERY_TIMEOUT_SECONDS=12
MISSING_EVIDENCE_NEGATIVE_TTL_SECONDS=3600
MISSING_EVIDENCE_MAX_PDF_PAGES=20
# 공지 한 건의 스키마 추출은 도구 사용이 없는 작업이므로 low로 지연을 줄입니다.
KNUASK_CODEX_REASONING_EFFORT=low
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIMENSIONS=1536
EMBEDDING_PROVIDER=ollama
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_EMBEDDING_MODEL=bge-m3
OLLAMA_EMBEDDING_KEEP_ALIVE=30m
EMBEDDING_REQUEST_TIMEOUT=45
MOCK_AI=false
MOCK_CRAWLER=true
NOTICE_BASE_URL=https://web.kangnam.ac.kr
NOTICE_LIST_URL=https://web.kangnam.ac.kr/menu/f19069e6134f8f8aa7f689a4a675e66f.do
NOTICE_DETAIL_URL=https://web.kangnam.ac.kr/menu/board/info/f19069e6134f8f8aa7f689a4a675e66f.do
CRAWLER_MONTHS=12
CRAWLER_MAX_PAGES=200
CRAWLER_INCREMENTAL_PAGES=10
CRAWLER_DELAY_SECONDS=0.8
CRAWLER_DETAIL_WORKERS=3
CRAWLER_INCLUDE_EVENTS=true
CRAWLER_EVENT_DETAIL_LIMIT=300
CRAWLER_EXTRACT_ATTACHMENTS=true
CRAWLER_ATTACHMENT_MAX_MB=25
CRAWLER_ATTACHMENT_CACHE_TTL_HOURS=24
CRAWLER_ATTACHMENT_CACHE_DIR=/app/data/attachment-cache
CRAWLER_SCHEDULE_ENABLED=false
CRAWLER_SCHEDULE_MINUTES=60
CRAWLER_DAILY_SCHEDULE_HOUR=2
CRAWLER_FULL_SCHEDULE_HOUR=3
CRAWLER_FULL_SCHEDULE_DAY=sun
MAX_INPUT_LENGTH=1000
ADMIN_API_TOKEN=replace-with-a-random-token-at-least-32-characters
SCHEMA_VERSION=2.0
EMBEDDING_VERSION=2.0
